{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "check:eslint": "eslint .",
        "check:eslint:fix": "eslint . --fix",
        "check:stylelint": "stylelint \"src/**/*.{scss,css}\"",
        "check:stylelint:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
        "check:spellcheck": "cspell \"src/**/*\" --cache",
        "format:check": "prettier --check .",
        "format": "prettier --write .",
        "check:all": "npm run check:eslint && npm run check:stylelint && npm run check:spellcheck && npm run format:check"
    },
    "dependencies": {
        "@emotion/react": "~11.14.0",
        "@emotion/styled": "~11.14.1",
        "@mui/material": "~7.3.9",
        "react": "~19.2.0",
        "react-dom": "~19.2.0"
    },
    "devDependencies": {
        "@cspell/dict-de-ch": "~1.3.2",
        "@eslint/js": "~9.39.1",
        "@types/react": "~19.2.7",
        "@types/react-dom": "~19.2.3",
        "@typescript-eslint/eslint-plugin": "~8.56.1",
        "@typescript-eslint/parser": "~8.56.1",
        "@vitejs/plugin-react": "~5.1.1",
        "cspell": "~9.7.0",
        "eslint": "~9.39.1",
        "eslint-plugin-import": "~2.32.0",
        "eslint-plugin-optimize-regex": "~1.2.1",
        "eslint-plugin-react": "~7.37.5",
        "eslint-plugin-react-hooks": "~7.0.1",
        "eslint-plugin-react-redux": "~4.2.2",
        "eslint-plugin-react-refresh": "~0.4.24",
        "eslint-plugin-simple-import-sort": "~12.1.1",
        "globals": "~16.5.0",
        "prettier": "~3.8.1",
        "sass": "~1.97.3",
        "stylelint": "~17.4.0",
        "stylelint-config-standard-scss": "~17.0.0",
        "stylelint-prettier": "~5.0.3",
        "stylelint-scss": "~7.0.0",
        "vite": "~7.3.1"
    }
}
