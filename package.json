{
    "name": "frontend",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "check:eslint": "eslint .",
        "check:eslint:fix": "eslint . --fix",
        "check:stylelint": "stylelint \"src/**/*.{scss,css}\"",
        "check:stylelint:fix": "stylelint \"src/**/*.{scss,css}\" --fix",
        "check:spellcheck": "cspell \"src/**/*\" --cache",
        "format:check": "prettier --check .",
        "format": "prettier --write .",
        "test:unit": "vitest run",
        "test:coverage": "vitest run --coverage",
        "check:all": "npm run check:eslint && npm run check:stylelint && npm run check:spellcheck && npm run format:check",
        "check:ci": "npm run check:all && npm run test:coverage && npm run build"
    },
    "dependencies": {
        "@emotion/react": "~11.14.0",
        "@emotion/styled": "~11.14.1",
        "@ericblade/quagga2": "~1.12.1",
        "@mui/icons-material": "~9.0.0",
        "@mui/material": "~9.0.0",
        "@mui/x-data-grid": "~9.0.2",
        "bwip-js": "~4.9.2",
        "html2canvas": "~1.4.1",
        "jspdf": "~4.2.1",
        "react": "~19.2.5",
        "react-dom": "~19.2.5",
        "react-router": "~7.14.0"
    },
    "devDependencies": {
        "@cspell/dict-de-ch": "~1.3.2",
        "@eslint/js": "~9.39.4",
        "@testing-library/jest-dom": "~6.9.1",
        "@testing-library/react": "~16.3.2",
        "@testing-library/user-event": "~14.6.1",
        "@types/bwip-js": "~3.2.3",
        "@types/react": "~19.2.7",
        "@types/react-dom": "~19.2.3",
        "@typescript-eslint/eslint-plugin": "~8.58.1",
        "@typescript-eslint/parser": "~8.58.1",
        "@vitejs/plugin-react": "~6.0.1",
        "@vitest/coverage-v8": "~4.1.4",
        "cspell": "~10.0.0",
        "eslint": "~9.39.4",
        "eslint-plugin-import": "~2.32.0",
        "eslint-plugin-react": "~7.37.5",
        "eslint-plugin-react-hooks": "~7.0.1",
        "eslint-plugin-react-refresh": "~0.5.2",
        "eslint-plugin-simple-import-sort": "~13.0.0",
        "globals": "~17.5.0",
        "jsdom": "~29.0.2",
        "prettier": "~3.8.2",
        "sass": "~1.99.0",
        "stylelint": "~17.7.0",
        "stylelint-config-standard-scss": "~17.0.0",
        "stylelint-prettier": "~5.0.3",
        "stylelint-scss": "~7.0.0",
        "vite": "~8.0.8",
        "vitest": "~4.1.0"
    }
}
